# RA Controller — systemd environment overrides
# Copy to /etc/ra-controller/env and uncomment lines as needed.
# These values override the corresponding settings in param.yaml.

# Write per-component log files in addition to journald output.
# LOG_DIR=/var/log/ra-controller

# Backend listen port (overrides param.yaml: backend.port)
# BACKEND_PORT=8080

# SQLite database path (overrides param.yaml: backend.db_path)
# DB_PATH=/var/lib/ra-controller/controller.db

# Neighbour poll interval in seconds (overrides param.yaml: backend.fetch_interval)
# FETCH_INTERVAL=10

# Filter neighbours by interface name (overrides param.yaml: backend.neighbor_ifname)
# NEIGHBOR_IFNAME=
