# Build React frontend and serve via nginx (context: repo root)
FROM node:22-alpine AS builder
WORKDIR /app
COPY controller/frontend/package.json controller/frontend/package-lock.json ./
RUN npm ci
COPY controller/frontend/ .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY laboratory/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
